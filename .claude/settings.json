{
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Edit",
      "Write",
      "NotebookEdit",
      "WebFetch",
      "WebSearch",
      "Skill",
      "Bash",
      "PowerShell"
    ],
    "ask": [
      "PowerShell(git push*)",
      "Bash(git push*)"
    ],
    "deny": [
      "PowerShell(git push --force*)",
      "Bash(git push --force*)",
      "PowerShell(git push -f*)",
      "Bash(git push -f*)",
      "PowerShell(git reset --hard*)",
      "Bash(git reset --hard*)",
      "PowerShell(git clean -*)",
      "Bash(git clean -*)",
      "Bash(rm -rf*)",
      "Bash(rm -fr*)",
      "PowerShell(Remove-Item -Recurse*)",
      "PowerShell(Remove-Item -Force -Recurse*)"
    ]
  }
}
